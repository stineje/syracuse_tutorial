/MSAVE { /mStat save def } def
/MRESTORE { mStat restore } def
/SET { exch def } def
/SF { /wi SET theFont [wi 0 0 FSIZE 0 0] makefont setfont } def
/L { newpath moveto lineto stroke } def
/VL { 2 index exch L } def
/HL { 1 index L } def
/BOX { /@yb SET /@xb SET /@yt SET /@xt SET newpath
 @xb @yb moveto @xb @yt lineto @xt @yt lineto @xt @yb lineto closepath } def
/SL { moveto show } def
/SR { exch dup /@xr SET 2 index stringwidth pop sub dup
 0 le { pop 0 @xr 3 -1 roll SC } { exch FSIZE 2 div sub moveto show }
 ifelse } def
/SCP { /@s SET @s stringwidth pop /@sw SET @sw 2 div sub
 dup @sw add maxX gt { pop maxX @sw sub } if exch moveto @s show } def
/SC { FSIZE 2 div sub /@y SET /@x2 SET /@x1 SET /@s SET
 /@l @x2 @x1 sub def /@x @x1 @x2 add 2 div def
 /@w @s stringwidth pop def @l @w gt
 { @y @x @s SCP }
 { @l FSIZE mul @w 1 add div dup MINFSIZE lt
 { pop } { /svf currentfont def SF @y @x @s SCP svf setfont } ifelse }ifelse
} def
/LE { exch GX GY FSIZE 2 div add SR /@x GX def
 { dup stringwidth pop /@w SET /@x @x FSIZE add def @x @w add
 720 ge { /@x GX FSIZE add def /GY GY FSIZE 2 add sub def } if
 @x GY SL /@x @x @w add def } repeat /GY GY FSIZE 4 add sub def } def
/FSIZE 9 def /MINFSIZE 4 def /maxX 718 def
612 0 translate
90 rotate
36 56 translate
1 setlinecap 0.6 setlinewidth 
/theFont /Helvetica findfont def FSIZE SF
